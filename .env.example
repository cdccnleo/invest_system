# ─── 数据库 ───────────────────────────────────────────
# PostgreSQL（Docker 或本地安装）
DATABASE_URL=postgresql://invest_admin:<password>@localhost:5432/investpilot
DB_HOST=localhost
DB_PORT=5432
DB_USER=invest_admin
DB_NAME=investpilot
DB_PASSWORD=<your_db_password>

# ─── DeepSeek API ─────────────────────────────────────
# 申请地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=<your_deepseek_api_key>
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─── Ollama 本地模型 ─────────────────────────────────
# 本地运行: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_MODEL=gemma4:e4b

# ─── 数据路径 ─────────────────────────────────────────
# 持仓文件（支持国金/天天基金/广发格式）
POSITIONS_CSV=/mnt/d/Hold/invest-data/positions.csv
HISTORY_DIR=/mnt/d/Hold/invest-data/history

# ─── 消息推送 ─────────────────────────────────────────
# Server酱（微信推送）: https://sct.ftqq.com/
SERVERCHAN_SENDKEY=<your_serverchan_sendkey>

# 飞书群机器人 Webhook
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/<your_webhook_id>

# ─── 加密密钥 ─────────────────────────────────────────
# AES-256 加密密钥（32字符），用于持仓敏感字段加密
# 生成方式: python3 -c "import secrets; print(secrets.token_hex(32))"
DB_ENCRYPTION_KEY=<your_32_char_hex_key>

# ─── 仪表盘密码 ──────────────────────────────────────
DASHBOARD_PASSWORD=<your_dashboard_password>
